{
  "manifest_version": 3,
  "name": "LeadPilot AI — LinkedIn Sales Agent",
  "version": "1.0.0",
  "description": "AI-powered LinkedIn messaging agent for automated lead qualification and outreach.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "https://staging-api.getaivora.co/*",
    "https://kvlfpwzmjxuapjheknnj.supabase.co/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
